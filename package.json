{
  "name": "@okoboji/engine-ai",
  "version": "0.13.2",
  "description": "Supercharge Claude Code in your terminal — build, mobile-check, and ship deployable apps to GitHub + Vercel. One command install, auto-connects.",
  "bin": {
    "engine-ai": "bin/engine-ai.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "postinstall": "node -e \"require(require('path').join(require('path').dirname(process.env.npm_package_json),'bin','postinstall.js'))\"",
    "preuninstall": "node -e \"require(require('path').join(require('path').dirname(process.env.npm_package_json),'bin','preuninstall.js'))\"",
    "release": "node scripts/release.js"
  },
  "files": [
    "bin/",
    "mcp/",
    "skills/",
    "commands/",
    "agents/",
    "hooks/",
    "docs/",
    "install.sh",
    "README.md"
  ],
  "keywords": [
    "claude-code",
    "claude",
    "mcp",
    "coding-agent",
    "scaffold",
    "deploy",
    "vercel",
    "github",
    "mobile-responsive",
    "wsl",
    "ai"
  ],
  "engines": {
    "node": ">=18"
  },
  "os": [
    "linux",
    "darwin"
  ],
  "repository": {
    "type": "git",
    "url": "github:MoblyJ/engine-ai"
  },
  "homepage": "https://github.com/MoblyJ/engine-ai#readme",
  "license": "MIT"
}
